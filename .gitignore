# Environment / secrets — never commit
.env
.env.*

# Generated/downloaded data — not source of truth
# data/seeds/ is explicitly kept below
data/
!data/seeds/
!data/seeds/**

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# CDK outputs and build artefacts
cdk-outputs.json
infra/cdk.out/

# Claude Code session files
.claude/

# Generated standalone HTML (regenerated from webapp/index.html + data/)
webapp/index_standalone.html
webapp/index_standalone_backup.html

# Local rollup data (S3 in production, local files from make invoke / testing)
rollups/
webapp/rollups/

# Separate sub-projects
agent-test-harness/
.gstack/
